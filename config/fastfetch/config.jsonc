// execute with: fastfetch --colors-block-range-start 9 --colors-block-width 3

{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/cat.txt",
        "color": {"1": "magenta"},
        "padding": {
            "top": 2,
            "right": 6
        }
    },
    "display": {
        "separator": ""
    },
    "modules": [
	"break",
	{
            "type": "title",
            "key": "  ",
        },
	{
            "type": "custom",
            "format": "------------------------------------------------",
        },
        {
            "type": "os",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "kernel",
            "key": "  ",
            "keyColor": "magenta",
        },
        {
            "type": "host",
            "format": "{5} {1}",
            "key": "󰌢  ",
            "keyColor": "magenta",
        },
        {
            "type": "packages",
            "format": "{} (RPM)",
            "key": "  ",
            "keyColor": "magenta",  
        },
        {
            "type": "shell",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "terminal",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "wm",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "wmtheme",
            "key": "󰉼  ",
            "keyColor": "magenta",
        },
        {
            "type": "icons",
            "key": "  ",
            "keyColor": "magenta",
        },
        {
            "type": "cursor",
            "key": "󰇀  ",
            "keyColor": "magenta", 
        },
        {
            "type": "terminalfont",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "uptime",
            "key": "  ",
            "keyColor": "magenta", 
        },
        {
            "type": "custom",
            "format": "------------------------------------------------",
        },
        
        {
            "type": "colors",
            "symbol": "circle",
        },
        
        "break",
        "break",
    ]
}
