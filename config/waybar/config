{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 13,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock", "tray"],
  "modules-right": ["memory", "network", "pulseaudio", "battery", "custom/notification"],
  
  "clock": {
   "format": "  {:%a %d %b  %I:%M %p}",
   "on-click": "gnome-calendar"
  },

  "pulseaudio": {
    "format": "ㅤ{volume}%",
    "format-muted": "  MUTED",
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  },

  "network": {
    "format-wifi": "󰤨ㅤ{signalStrength}%",
    "format-ethernet": "󰈀ㅤWIRED",
    "format-disconnected": "󰖪",
    "on-click": "control -wifi"
  },

  "cpu": {
    "format": "ㅤ{usage}%",
    "on-click": "gnome-system-monitor"
  },

  "memory": {
    "format": "ㅤ{used:0.1f}G",
   "on-click": "btop"
  },

  "battery": {
    "format": "ㅤ{capacity}%",
    "format-charging": "󱐋  {capacity}%",
    "tooltip": true,
    "path": "/sys/class/power_supply/BAT0"
  },

  "tray": {
    "spacing": 10
  },

  "hyprland/window": {
    "max-length": 20,
  }
}
